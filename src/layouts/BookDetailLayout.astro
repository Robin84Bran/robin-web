---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { localeChrome } from '../data/locales';
import type { SiteLocale } from '../lib/i18n';
import BaseLayout from './BaseLayout.astro';

type SchemaObject = Record<string, unknown>;

interface Props {
  title: string;
  thesis: string;
  description: string;
  path: string;
  image?: string;
  schema?: SchemaObject | SchemaObject[];
  cover: ImageMetadata;
  coverAlt: string;
  status: string;
  theme: string;
  shortCode: string;
  locale?: SiteLocale;
  titleSecondary?: string;
  collectionHref?: string;
  collectionLabel?: string;
  descriptionLines?: string[];
}

const {
  title,
  thesis,
  description,
  path,
  image,
  schema,
  cover,
  coverAlt,
  status,
  theme,
  shortCode,
  locale = 'en',
  titleSecondary,
  collectionHref = locale === 'cn' ? '/cn/books/' : '/books/',
  collectionLabel = localeChrome[locale].booksLabel,
  descriptionLines,
} = Astro.props;
---

<BaseLayout
  description={description}
  image={image}
  locale={locale}
  path={path}
  schema={schema}
  title={`${title} | Robin Xie`}
>
  <section class="section-shell pt-0">
    <div class="glass-card manuscript-stage p-5 sm:p-7 lg:p-8">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,19rem)_1fr] xl:items-start">
        <div class="manuscript-cover-frame mx-auto w-full max-w-[19rem]">
          <Image
            alt={coverAlt}
            class="h-full w-full object-cover"
            loading="eager"
            sizes="(min-width: 1280px) 19rem, 80vw"
            src={cover}
            width={760}
          />
        </div>

        <div class="manuscript-copy-panel max-w-3xl">
          <nav aria-label="Breadcrumb" class="type-action flex flex-wrap items-center gap-2 text-[var(--color-muted)]">
            <a class="transition-colors hover:text-[var(--color-ink)]" href={collectionHref}>{collectionLabel}</a>
            <span aria-hidden="true">/</span>
            <span class="text-[var(--color-ink)]">{title}</span>
          </nav>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <p class="eyebrow">{status}</p>
            <span class="type-meta rounded-full border border-[var(--color-line)] px-3 py-1 text-[var(--color-muted)]">
              {theme}
            </span>
            <span class="type-meta rounded-full border border-[var(--color-line)] px-3 py-1 text-[var(--color-muted)]">
              {shortCode}
            </span>
          </div>

          <h1 class="type-heading mt-5 text-[var(--color-ink)] sm:text-[clamp(2.5rem,4vw,3.7rem)]">
            {title}
          </h1>
          {titleSecondary && <p class="type-action mt-3 text-[var(--color-muted)]">{titleSecondary}</p>}
          <p class="type-lead mt-5 max-w-3xl text-[var(--color-ink)]/84">{thesis}</p>
          {
            descriptionLines ? (
              <div class="type-body mt-6 max-w-3xl space-y-2 text-[var(--color-muted)]">
                {descriptionLines.map((line) => <p>{line}</p>)}
              </div>
            ) : (
              <p class="type-body mt-6 max-w-3xl text-[var(--color-muted)]">{description}</p>
            )
          }

          <div class="mt-8 flex flex-wrap gap-3">
            <slot name="intro-actions" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <slot />
</BaseLayout>
