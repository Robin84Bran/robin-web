---
import { getCollection, getEntry, render } from 'astro:content';
import FeaturedBooks from '../components/home/FeaturedBooks.astro';
import Hero from '../components/home/Hero.astro';
import HomeAbout from '../components/home/HomeAbout.astro';
import IdentityStrip from '../components/home/IdentityStrip.astro';
import PortfolioPreview from '../components/home/PortfolioPreview.astro';
import PressPreview from '../components/home/PressPreview.astro';
import ProjectsGrid from '../components/home/ProjectsGrid.astro';
import { aboutPillars, operatingPrinciples, pressFeatures, siteConfig } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { featuredOnly, sortCollectionByOrder } from '../lib/content';
import { createPersonSchema, createWebsiteSchema } from '../lib/seo';

const books = featuredOnly(sortCollectionByOrder(await getCollection('books'))).slice(0, 4);
const projects = featuredOnly(sortCollectionByOrder(await getCollection('projects'))).slice(0, 4);
const aboutEntry = await getEntry('pages', 'about');

if (!aboutEntry) {
  throw new Error('Missing about page content.');
}

const { Content: AboutContent } = await render(aboutEntry);
---

<BaseLayout
  description={siteConfig.description}
  image="/og/home.jpg"
  path="/"
  schema={[createWebsiteSchema(), createPersonSchema()]}
  title={siteConfig.title}
>
  <Hero />
  <div class="section-reveal section-reveal-1">
    <IdentityStrip />
  </div>
  <div class="section-reveal section-reveal-2">
    <ProjectsGrid projects={projects} />
  </div>
  <div class="section-reveal section-reveal-3">
    <PortfolioPreview
      action="Enter portfolio"
      description="Time, attention, and capital, placed to grow and compound."
      eyebrow="Portfolio"
      href="/portfolio/"
      note="Bitcoin is the truth. AGI finds the meaning. Eight allocations. One unified field."
      title="Portfolio"
    />
  </div>
  <div class="section-reveal section-reveal-4">
    <PressPreview
      description="A few public moments from before the system had a name."
      eyebrow="Press"
      items={pressFeatures}
      title="Earlier footprints."
    />
  </div>
  <div class="section-reveal section-reveal-5">
    <FeaturedBooks books={books} />
  </div>
  <div class="section-reveal section-reveal-5">
    <HomeAbout
      description={aboutEntry.data.description}
      eyebrow={aboutEntry.data.kicker}
      pillars={aboutPillars}
      principles={operatingPrinciples}
      principlesDescription="Clarity, warmth, and the long arc."
      principlesEyebrow="Principles"
      principlesTitle="What holds."
      title="Robin Xie"
    >
      <div slot="body">
        <AboutContent />
      </div>
    </HomeAbout>
  </div>
</BaseLayout>
