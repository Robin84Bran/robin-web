---
import { getEntry, render } from 'astro:content';
import PageIntro from '../components/common/PageIntro.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { nowSignals, pressFeatures } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { createPersonSchema } from '../lib/seo';

const entry = await getEntry('pages', 'now');

if (!entry) {
  throw new Error('Missing now page content.');
}

const { Content } = await render(entry);
const openLoops = [
  'A bank is more than a license.',
  'Scale is more than a number.',
  'Payments matter when they reach the people legacy rails ignored.',
];
---

<BaseLayout
  description="Earlier public moments from Robin Xie across blockchain banking, cross-border finance, and financial inclusion."
  image="/og/home.jpg"
  path="/now/"
  schema={createPersonSchema()}
  title="Press | Robin Xie"
>
  <PageIntro
    description={entry.data.description}
    kicker={entry.data.kicker}
    title={entry.data.title}
    updated={entry.data.updated}
  />

  <section class="section-shell">
    <div class="prose-robin">
      <Content />
    </div>
  </section>

  <section class="section-shell pt-0">
    <SectionHeading
      description="Three lines through the earlier work."
      eyebrow="Context"
      title="Before the system had a name."
    />

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        nowSignals.map((signal) => (
          <article class="glass-card p-6">
            <p class="type-label text-[var(--color-accent)]">
              {signal.label}
            </p>
            <p class="type-body mt-3 text-[var(--color-muted)]">{signal.value}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-0">
    <SectionHeading
      description="What the old work still leaves behind."
      eyebrow="Afterimage"
      title="The questions remain."
    />

    <div class="mt-8 grid gap-4">
      {
        openLoops.map((loop) => (
          <article class="glass-card p-6">
            <p class="type-body text-[var(--color-muted)]">{loop}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-0">
    <SectionHeading
      description="A few public moments from before the system had a name."
      eyebrow="Press"
      title="Earlier footprints."
    />

    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {
        pressFeatures.map((item) => (
          <a class="glass-card p-6 no-underline transition-transform hover:-translate-y-0.5" href={item.href} rel="noreferrer" target="_blank">
            <p class="eyebrow">{item.source}</p>
            <h2 class="type-card-title mt-4 text-[var(--color-ink)]">{item.title}</h2>
            <p class="type-body mt-4 text-[var(--color-muted)]">{item.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
