---
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import PageIntro from '../components/common/PageIntro.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import { getBookManuscript, getBookPath } from '../lib/books';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortCollectionByOrder } from '../lib/content';
import { createBookSchemas, createPersonSchema } from '../lib/seo';

const entry = await getEntry('pages', 'books');
const books = sortCollectionByOrder(await getCollection('books')).map((book) => ({
  entry: book,
  manuscript: getBookManuscript(book.id),
}));

if (!entry) {
  throw new Error('Missing books page content.');
}

const { Content } = await render(entry);
---

<BaseLayout
  description="Living book manuscripts by Robin Xie on AGI, leverage, longevity, and financial systems."
  image="/og/books.jpg"
  path="/books/"
  schema={[createPersonSchema(), ...createBookSchemas(books.map(({ entry }) => entry))]}
  title="Books | Robin Xie"
>
  <PageIntro
    description={entry.data.description}
    kicker={entry.data.kicker}
    title={entry.data.title}
    updated={entry.data.updated}
  />

  <section class="section-shell">
    <div class="prose-robin">
      <Content />
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="grid gap-6 xl:grid-cols-2">
      {
        books.map(({ entry: book, manuscript }) => (
          <article class="manuscript-shelf-card" id={book.id}>
            <a
              class="manuscript-cover-frame block"
              href={getBookPath(book.id)}
              aria-label={`Enter ${book.data.title} manuscript`}
            >
              <Image
                alt={manuscript.coverAlt}
                class="h-full w-full object-cover"
                loading="eager"
                sizes="(min-width: 1280px) 18rem, (min-width: 640px) 11rem, 100vw"
                src={manuscript.cover}
                width={440}
              />
            </a>

            <div class="flex h-full flex-col">
              <div class="flex flex-wrap items-center gap-3">
                <p class="eyebrow">{book.data.status}</p>
                <span class="type-meta rounded-full border border-[var(--color-line)] px-3 py-1 text-[var(--color-muted)]">
                  {book.data.theme}
                </span>
              </div>

              <h2 class="type-card-title mt-5 text-[var(--color-ink)]">{book.data.title}</h2>
              <p class="type-body mt-4 max-w-xl text-[var(--color-muted)]">{manuscript.thesis}</p>
              <div class="mt-6">
                <ButtonLink href={getBookPath(book.id)} variant="secondary">
                  Enter manuscript
                </ButtonLink>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-10">
      <ButtonLink href="/writing/" variant="ghost">
        More writing lives on Ghost
      </ButtonLink>
    </div>
  </section>
</BaseLayout>
