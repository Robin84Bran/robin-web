---
import { socialLinks } from '../../data/site';
import ButtonLink from '../ui/ButtonLink.astro';

interface ContactLink {
  label: string;
  href: string;
  blurb: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  links?: readonly ContactLink[];
  primaryCtaLabel?: string;
}

const {
  eyebrow = 'Connect',
  title = 'Start where the work already lives.',
  description = 'Use the channel that fits the context. GitHub stays closest to the work.',
  links = socialLinks,
  primaryCtaLabel = 'Visit GitHub',
} = Astro.props;

const [githubLink, ...otherLinks] = links;
---

<section class="section-shell">
  <div class="glass-card p-7 sm:p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow">{eyebrow}</p>
        <h2 class="type-heading mt-3 text-[var(--color-ink)]">{title}</h2>
        <p class="type-body mt-4 max-w-xl text-[var(--color-muted)]">{description}</p>
      </div>
      <ButtonLink className="self-start lg:self-auto" external href={githubLink.href}>
        {primaryCtaLabel}
      </ButtonLink>
    </div>

    <nav aria-label="Contact links" class="mt-7 flex flex-wrap gap-x-5 gap-y-3">
      {
        otherLinks.map((link) => (
          <a
            class="type-action text-[var(--color-muted)] no-underline transition-colors duration-500 hover:text-[var(--color-ink)]"
            href={link.href}
            rel="noreferrer"
            target="_blank"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</section>
