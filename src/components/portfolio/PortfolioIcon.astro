---
type IconName =
  | 'bitcoin'
  | 'ethereum'
  | 'usdt'
  | 'usdc'
  | 'chatgpt'
  | 'oceaneering'
  | 'nasa'
  | 'tesla'
  | 'spacex'
  | 'gifted'
  | 'rice'
  | 'isunone'
  | 'robinos';

interface Props {
  icon: IconName;
  label: string;
  href: string;
}

const { icon, label, href } = Astro.props;
---

<a
  aria-label={label}
  class="portfolio-icon"
  data-portfolio-icon={icon}
  href={href}
  rel="noreferrer"
  target="_blank"
  title={label}
>
  <svg aria-hidden="true" fill="none" viewBox="0 0 48 48">
    {
      icon === 'bitcoin' && (
        <>
          <circle cx="24" cy="24" r="15"></circle>
          <path d="M19 14v20M17 18h10.5c5 0 5 7 0 7H19h9.5c5.2 0 5.2 7 0 7H17M23 11v5M27 11v5M23 32v5M27 32v5"></path>
        </>
      )
    }
    {
      icon === 'ethereum' && (
        <>
          <path d="M24 7 13 24l11 6 11-6L24 7Z"></path>
          <path d="m13 24 11 17 11-17-11 6-11-6Z"></path>
          <path d="M24 7v23"></path>
        </>
      )
    }
    {
      icon === 'usdt' && (
        <>
          <circle cx="24" cy="24" r="15"></circle>
          <path d="M15 16h18M24 16v17M18 21c3.5 2.2 8.5 2.2 12 0M17 24c4.4 2.8 9.6 2.8 14 0"></path>
        </>
      )
    }
    {
      icon === 'usdc' && (
        <>
          <path d="M16 11a16 16 0 0 0 0 26M32 11a16 16 0 0 1 0 26"></path>
          <path d="M28.5 18.5c-1.2-1.4-3-2.1-5.1-2.1-2.8 0-4.9 1.5-4.9 3.8 0 5.9 11.2 2.3 11.2 8.3 0 2.3-2.1 3.9-5.2 3.9-2.4 0-4.5-.8-5.9-2.4M24 12v4M24 32v4"></path>
        </>
      )
    }
    {
      icon === 'chatgpt' && (
        <>
          {
            Array.from({ length: 6 }).map((_, index) => (
              <path
                d="M24 10c5.8 0 9 3.5 8.3 8.2-.5 3.5-3.2 5.5-8.3 8.2-5.1-2.7-7.8-4.7-8.3-8.2C15 13.5 18.2 10 24 10Z"
                transform={`rotate(${index * 60} 24 24)`}
              ></path>
            ))
          }
          <circle cx="24" cy="24" r="4.5"></circle>
        </>
      )
    }
    {
      icon === 'oceaneering' && (
        <>
          <circle cx="24" cy="24" r="15"></circle>
          <circle cx="24" cy="24" r="8.5"></circle>
          <path d="M11 27c4-3 7-3 11 0s7 3 15-1M12 32c4-2.4 7-2.4 11 0s7 2.4 13-.8"></path>
        </>
      )
    }
    {
      icon === 'nasa' && (
        <>
          <circle cx="24" cy="24" r="14"></circle>
          <ellipse cx="24" cy="24" rx="19" ry="7.5" transform="rotate(-28 24 24)"></ellipse>
          <path d="m24 12 1.6 6.4L32 20l-6.4 1.6L24 28l-1.6-6.4L16 20l6.4-1.6L24 12Z"></path>
          <circle cx="33.5" cy="13.5" r="1.5"></circle>
        </>
      )
    }
    {
      icon === 'tesla' && (
        <>
          <path d="M12 15c7.5-4.7 16.5-4.7 24 0M16 18c5.2-2.7 10.8-2.7 16 0M24 17v21M19 23c1.4-2 3.1-3 5-3s3.6 1 5 3"></path>
        </>
      )
    }
    {
      icon === 'spacex' && (
        <>
          <path d="m14 15 20 20M34 14 14 35"></path>
          <path d="M7 31c8-11 19-16 34-15-7 1-12 4-16 9"></path>
          <path d="m36 12 5 4-6 2"></path>
        </>
      )
    }
    {
      icon === 'gifted' && (
        <>
          <path d="m24 8 3.6 10.4L38 22l-10.4 3.6L24 36l-3.6-10.4L10 22l10.4-3.6L24 8Z"></path>
          <circle cx="24" cy="22" r="4.2"></circle>
          <path d="M9 36c4-4 8-6 12-6M39 36c-4-4-8-6-12-6"></path>
        </>
      )
    }
    {
      icon === 'rice' && (
        <>
          <path d="M13 10h22v17c0 7-5.4 11-11 13-5.6-2-11-6-11-13V10Z"></path>
          <circle cx="19.5" cy="22" r="4"></circle>
          <circle cx="28.5" cy="22" r="4"></circle>
          <path d="m24 23-2 4h4l-2-4ZM16 15c5-2.6 11-2.6 16 0"></path>
        </>
      )
    }
    {
      icon === 'isunone' && (
        <>
          <circle cx="24" cy="24" r="10"></circle>
          <ellipse cx="24" cy="24" rx="18" ry="7" transform="rotate(-28 24 24)"></ellipse>
          <path d="M24 7v4M24 37v4M7 24h4M37 24h4M12 12l3 3M33 33l3 3M36 12l-3 3M15 33l-3 3"></path>
          <path d="M24 18v12M21 20l3-2"></path>
        </>
      )
    }
    {
      icon === 'robinos' && (
        <>
          <path d="M8 24c2.5-9 8-14 16-14s13.5 5 16 14c-5.4-2.6-10.6-2.6-16 0-5.4-2.6-10.6-2.6-16 0Z"></path>
          <path d="M24 10v24c0 4-5 5-7 1M14 21v6M34 21v6M18 17v5M30 17v5"></path>
          <circle cx="14" cy="29" r="1.5"></circle>
          <circle cx="34" cy="29" r="1.5"></circle>
          <circle cx="18" cy="24" r="1.5"></circle>
          <circle cx="30" cy="24" r="1.5"></circle>
        </>
      )
    }
  </svg>
  <span class="sr-only">{label}</span>
</a>
