---
import SectionHeading from '../ui/SectionHeading.astro';

interface AboutPillar {
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  pillars: readonly AboutPillar[];
  principles: readonly string[];
  principlesEyebrow: string;
  principlesTitle: string;
  principlesDescription: string;
}

const {
  eyebrow,
  title,
  description,
  pillars,
  principles,
  principlesEyebrow,
  principlesTitle,
  principlesDescription,
} = Astro.props;
---

<section class="section-shell" id="about">
  <SectionHeading description={description} eyebrow={eyebrow} title={title} />

  <div class="mt-9 grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
    <div class="prose-robin prose-robin--lead">
      <slot name="body" />
    </div>

    <div class="space-y-4">
      {
        pillars.map((pillar) => (
          <article class="glass-card p-6">
            <h3 class="type-card-title text-[var(--color-ink)]">{pillar.title}</h3>
            <p class="type-body mt-3 text-[var(--color-muted)]">{pillar.description}</p>
          </article>
        ))
      }
    </div>
  </div>

  <div class="mt-14">
    <SectionHeading
      description={principlesDescription}
      eyebrow={principlesEyebrow}
      title={principlesTitle}
    />

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        principles.map((principle) => (
          <article class="glass-card p-6">
            <p class="type-body text-[var(--color-muted)]">{principle}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
