---
import heroWatchUrl from '../../../pics/hero_watch.jpg?url';
import { heroLens, siteConfig } from '../../data/site';
import ButtonLink from '../ui/ButtonLink.astro';
---

<section class="section-shell relative pt-6 sm:pt-10">
  <div aria-hidden="true" class="hero-depth-field pointer-events-none absolute inset-x-[5%] top-0 -z-10"></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-[16%] top-0 -z-10 h-56 rounded-full bg-[radial-gradient(circle,rgba(232,188,205,0.18),rgba(159,182,201,0.08)_34%,transparent_72%)] blur-3xl"
  ></div>

  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(17rem,22rem)] lg:items-center lg:gap-16">
    <div class="hero-rise max-w-[40rem] pt-2 lg:max-w-none">
      <p class="type-hero-kicker">{siteConfig.heroEyebrow}</p>

      <h1 class="type-display mt-6 max-w-[14ch] text-[var(--color-ink)]">
        {siteConfig.heroTitle}
      </h1>

      <p class="type-lead mt-5 max-w-[19.5rem] text-[var(--color-accent-strong)] sm:max-w-[32rem]">
        {siteConfig.heroSubline}
      </p>

      <div class="prose-robin prose-robin--lead mt-7 max-w-[19.5rem] text-[var(--color-muted)] sm:max-w-[34rem]">
        {siteConfig.heroBody.map((line) => <p>{line}</p>)}
      </div>

      <div class="mt-9 flex flex-wrap gap-3">
        <ButtonLink external href={siteConfig.officialWebsiteUrl}>
          Official website
        </ButtonLink>
        <ButtonLink external href={siteConfig.linkedinUrl} variant="secondary">
          LinkedIn
        </ButtonLink>
      </div>

      <div class="hero-rise-delayed mt-9 max-w-[19.5rem] sm:max-w-[34rem]">
        <p class="eyebrow">Currently</p>
        <div class="mt-4 space-y-2.5">
          {
            heroLens.map((item) => (
              <p class="type-meta text-[var(--color-muted)]">
                <span class="text-[var(--color-ink)]">{item.label}.</span> {item.value}
              </p>
            ))
          }
        </div>
      </div>
    </div>

    <div class="hero-rise-delayed lg:justify-self-end">
      <div class="hero-portrait-shell p-3">
        <div class="relative overflow-hidden rounded-[1.6rem]">
          <a
            aria-label="Open iamrobin.eth on ENS"
            class="group block"
            href={siteConfig.ensUrl}
            rel="noreferrer"
            target="_blank"
          >
            <img
              alt="Robin Xie portrait"
              class="aspect-[829/1122] w-full object-cover brightness-[0.98] saturate-[0.82] sepia-[0.08] transition-transform duration-[1600ms] ease-out group-hover:scale-[1.01]"
              decoding="async"
              loading="eager"
              src={heroWatchUrl}
            />
          </a>
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_44%,rgba(57,48,39,0.08)_78%,rgba(57,48,39,0.16)_100%)]"></div>
        </div>
        <p class="type-meta mt-4 text-[var(--color-muted)]">{siteConfig.releaseLabel}</p>
      </div>
    </div>
  </div>
</section>
