---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  external?: boolean;
  className?: string;
}

const { href, variant = 'primary', external = false, className = '' } = Astro.props;

const variants = {
  primary:
    'border-[rgba(188,157,112,0.28)] bg-[rgba(250,247,241,0.92)] text-[var(--color-ink)] hover:border-[rgba(188,157,112,0.48)] hover:bg-[rgba(255,252,247,0.96)]',
  secondary:
    'border-[var(--color-line)] bg-[rgba(255,255,255,0.5)] text-[var(--color-ink)] hover:border-[rgba(188,157,112,0.4)] hover:bg-[rgba(255,255,255,0.7)]',
  ghost:
    'border-transparent bg-transparent text-[var(--color-muted)] hover:text-[var(--color-ink)]',
};
---

<a
  href={href}
  class:list={[
    'type-action inline-flex items-center gap-2 rounded-full border px-4 py-2.5 transition-all duration-700 ease-out hover:-translate-y-[1px]',
    variants[variant],
    className,
  ]}
  rel={external ? 'noreferrer' : undefined}
  target={external ? '_blank' : undefined}
>
  <slot />
  <span aria-hidden="true">{external ? '↗' : '→'}</span>
</a>
