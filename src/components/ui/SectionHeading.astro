---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { eyebrow, title, description, centered = false } = Astro.props;
---

<div class:list={['max-w-3xl', centered && 'mx-auto text-center']}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="type-heading mt-3 text-[var(--color-ink)]">{title}</h2>
  {description && <p class="type-body mt-4 text-[var(--color-muted)]">{description}</p>}
</div>
