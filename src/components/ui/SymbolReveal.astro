---
interface Props {
  kind:
    | 'agi'
    | 'block'
    | 'longevity'
    | 'derivatives'
    | 'robinos'
    | 'quant'
    | 'watts'
    | 'children';
  text: string;
  label: string;
}

const { kind, text, label } = Astro.props;
---

<div aria-label={label} class="symbol-reveal group" tabindex="0">
  <div class="symbol-glyph" aria-hidden="true">
    <svg fill="none" viewBox="0 0 64 64">
      {
        kind === 'agi' && (
          <>
            <path d="M35 10 20 33h10l-3 21 17-28H34l1-16z"></path>
          </>
        )
      }
      {
        kind === 'block' && (
          <>
            <path d="M17 32c0-8 6-14 14-14 7 0 13 5 14 12 1 7-3 14-10 17-7 3-15 0-20-6"></path>
            <path d="M28 19c-6 2-10 7-10 14 0 6 4 11 10 13"></path>
            <path d="M39 16l7 4-2 7"></path>
            <path d="M24 46c5 2 10 2 15 0"></path>
          </>
        )
      }
      {
        kind === 'longevity' && (
          <>
            <path d="M32 50V16"></path>
            <path d="M32 22c-5 0-9-4-11-9"></path>
            <path d="M32 26c5 0 9-4 11-9"></path>
            <path d="M32 32c-6 0-11 5-13 10"></path>
            <path d="M32 36c6 0 11 5 13 10"></path>
          </>
        )
      }
      {
        kind === 'derivatives' && (
          <>
            <path d="M12 40c6-8 12-12 18-12 7 0 10 8 16 8 6 0 10-4 18-16"></path>
            <path d="M18 22v20"></path>
            <path d="M30 18v24"></path>
            <path d="M42 26v16"></path>
          </>
        )
      }
      {
        kind === 'robinos' && (
          <>
            <path d="M32 16c-7 0-13 6-13 13v5c0 8 5 15 13 19 8-4 13-11 13-19v-5c0-7-6-13-13-13z"></path>
            <path d="M32 16v37"></path>
            <path d="M19 31c-3 0-6 2-8 5 3 2 6 3 10 2"></path>
            <path d="M45 31c3 0 6 2 8 5-3 2-6 3-10 2"></path>
          </>
        )
      }
      {
        kind === 'quant' && (
          <>
            <path d="M14 44h36"></path>
            <path d="M20 18v22M20 24h6M20 34h6"></path>
            <path d="M32 14v26M32 20h6M32 30h6"></path>
            <path d="M44 24v16M44 28h6M44 36h6"></path>
            <path d="M16 40l10-8 10 2 12-10"></path>
          </>
        )
      }
      {
        kind === 'watts' && (
          <>
            <rect height="11" rx="2.5" width="11" x="18" y="18"></rect>
            <rect height="11" rx="2.5" width="11" x="35" y="35"></rect>
            <path d="M29 23h6M23 29v6M35 40h-6M40 35v-6"></path>
            <path d="M21 50l9-15h-6l4-13"></path>
          </>
        )
      }
      {
        kind === 'children' && (
          <>
            <path d="M14 42c4-10 10-15 18-15s14 5 18 15"></path>
            <path d="M22 42V28M42 42V28"></path>
            <path d="M24 24c2-3 5-5 8-5s6 2 8 5"></path>
            <circle cx="20" cy="46" r="2.5"></circle>
            <circle cx="44" cy="46" r="2.5"></circle>
          </>
        )
      }
    </svg>
  </div>
  <p class="sr-only">{label}</p>
  <p class="symbol-copy type-body">{text}</p>
</div>
