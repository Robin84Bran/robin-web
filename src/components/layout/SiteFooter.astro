---
import { localeChrome } from '../../data/locales';
import type { SiteLocale } from '../../lib/i18n';
import { siteConfig } from '../../data/site';

interface Props {
  locale?: SiteLocale;
}

const { locale = 'en' } = Astro.props;
const chrome = localeChrome[locale];
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-[rgba(6,16,24,0.32)]">
  <div class="mx-auto grid max-w-[72rem] gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:px-8">
    <div>
      <p class="font-[family:var(--font-display)] text-[1.75rem] leading-none tracking-[-0.035em] text-[var(--color-ink)]">
        {chrome.brandName}
      </p>
      <p class="type-meta mt-3 text-[var(--color-muted)]">
        © {year} {locale === 'cn' ? '谢玢' : locale === 'tw' ? '謝玢' : locale === 'jp' ? 'ロビン・シエ' : siteConfig.name}
      </p>
      <p class="type-meta mt-1 text-[var(--color-muted)]">
        {locale === 'cn' || locale === 'tw' ? siteConfig.releaseLabelCn : siteConfig.releaseLabel}
      </p>
    </div>

    <nav aria-label="Footer" class="flex flex-wrap items-start gap-x-5 gap-y-3">
      {
        chrome.footerLinks.map((link) => (
          <a
            class="type-action text-[var(--color-muted)] no-underline transition-colors duration-500 hover:text-[var(--color-ink)]"
            href={link.href}
            rel="noreferrer"
            target="_blank"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
